{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build-all",
            "type": "shell",
            "command": "g++",
            "args": [
                "-std=c++20",
                "*.cpp",
                "-g",
                "-o",
                "Random-Number-Guessing-Game"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "run",
            "type": "shell",
            "command": "${workspaceFolder}/Random-Number-Guessing-Game",
        }
    ]
}
